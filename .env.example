# =============================================================================
# Buildeo – șablon. Copiază la .env și completează. NU pune chei reale aici dacă
# comiți repo-ul public (folosește .env, care e ignorat de git).
# =============================================================================

# Prisma → Supabase Postgres: Dashboard → Settings → Database
# Copiază URI-urile exact din UI; adaugă &sslmode=require (sau ?sslmode=require) dacă lipsește.
# REGION din hostul pooler trebuie să fie al proiectului tău — altfel „Tenant or user not found”.
# Local poți seta DATABASE_URL = DIRECT_URL (direct 5432); pe Vercel folosește Transaction pooler (6543).
DATABASE_URL="postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_TOKEN=

# Buildeo Flipo KI (Replicate) – optional; ohne Werte: Keyword-Suche über Inserate
# Version = Hash aus replicate.com (Model → API → version id), nicht owner/name.
REPLICATE_API_TOKEN=
REPLICATE_FLIPO_VERSION=
# Zusätzliche model input Felder als JSON, z. B. {"max_new_tokens":512}
# REPLICATE_FLIPO_INPUT_JSON=

# Inserate: ownerId (User) verknüpft Anbieter mit Listing; Kontaktformular speichert ContactInquiry.
# Nach Schema-Änderung: prisma migrate deploy && npm run db:seed (Demo-Inserate → demo@buildeo.de)

# --- Supabase API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
